{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Aura Sentinel — Real-time C2 Botnet Detection & AIOps Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 20,
      "title": "🔱 AURA SENTINEL — Live Threat Intelligence",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "title": "🚨 Total C2 Alerts",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "sum(aura_alert_total)",
          "legendFormat": "Alerts"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "title": "☠️ C2 Hubs Dismantled",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "sum(aura_c2_hubs_detected_total)",
          "legendFormat": "C2 Hubs"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "title": "📨 Messages Processed",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "sum(aura_messages_consumed_total)",
          "legendFormat": "Messages"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "title": "🕵️ IPs Under Surveillance",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "sum(aura_active_tracked_ips)",
          "legendFormat": "Tracked IPs"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1.5 }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 3
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "🌡️ Average Network Entropy (0=Botnet, 3=Normal)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "((sum(aura_entropy_score) or vector(0)) + (aura_active_tracked_ips - (count(aura_entropy_score) or vector(0))) * 3) / aura_active_tracked_ips",
          "legendFormat": "Avg Entropy"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 21,
      "title": "📉 Entropy Drop Detection — Real-time C2 Beaconing Alerts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 6 },
      "id": 6,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "📉 Entropy Per Source IP — Drop = C2 Beaconing Detected",
      "description": "Shannon entropy of traffic byte sizes per source IP. Drops below 0.5 trigger REAPER alerts.",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "topk(10, aura_entropy_score)",
          "legendFormat": "{{src_ip}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 6 },
      "id": 7,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "🚨 Alert Rate (C2 Detections / min)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "sum(rate(aura_alert_total[1m])) * 60",
          "legendFormat": "Alerts/min"
        },
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "sum(rate(aura_messages_consumed_total[1m])) * 60",
          "legendFormat": "Messages/min"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 22,
      "title": "🕸️ Network Flow Volume — Top Talkers",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "id": 8,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "sum"] }
      },
      "title": "📊 Top 10 Byte Volume Flows",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "topk(10, rate(aura_bytes_total[1m]))",
          "legendFormat": "{{src_ip}} → {{dst_ip}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "src_ip" }, "properties": [{ "id": "custom.width", "value": 140 }] },
          { "matcher": { "id": "byName", "options": "dst_ip" }, "properties": [{ "id": "custom.width", "value": 140 }] },
          { "matcher": { "id": "byName", "options": "Value" },  "properties": [{ "id": "displayName", "value": "Total Bytes" }] }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "id": 9,
      "options": {
        "sortBy": [{ "displayName": "Total Bytes", "desc": true }]
      },
      "title": "📋 Flow Table — All Observed src→dst Pairs",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
          "expr": "topk(20, aura_bytes_total)",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "src_ip": "Source IP", "dst_ip": "Destination IP" } } }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["aura-sentinel", "c2-detection", "security", "aiops"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "🔱 Aura Sentinel — AIOps C2 Detection Dashboard",
  "uid": "aura-sentinel-v1",
  "version": 1
}
